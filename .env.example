RECLAIMO_API_ADDR=127.0.0.1:8080
RECLAIMO_DEMO_ENABLED=true
RECLAIMO_POLL_INTERVAL=5s
RECLAIMO_MAX_CHECKS_PER_PURCHASE=0

# Keep mock unless you intentionally want to spend Nimble trial calls.
RECLAIMO_NIMBLE_MODE=mock
NIMBLE_API_KEY=
NIMBLE_BASE_URL=https://sdk.nimbleway.com/v1
NIMBLE_DRIVER=vx6
NIMBLE_RENDER=false

CLICKHOUSE_ENABLED=false
CLICKHOUSE_ADDR=
CLICKHOUSE_DATABASE=reclaimo
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

RECOVERY_REPORT_URL=http://localhost:8080/api/reclaimo/recovery-report
PAYMENT_RAIL_URL=http://localhost:8080/x402/transaction

DATADOG_ENABLED=false
DD_SERVICE=reclaimo-api
DD_AGENT_ADDR=127.0.0.1:8126
DD_ENV=local

# Next.js proxy target for apps/web.
RECLAIMO_API_URL=http://127.0.0.1:8080
